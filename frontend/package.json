{
  "name": "face-recognition-app",
  "version": "1.0.0",
  "description": "Face recognition application built with React and Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-dev\" \"wait-on http://localhost:3000 && ping 127.0.0.1 -n 3 > nul && electron .\"",
    "dev-separate": "echo Start React server with: npm run react-dev && echo Start Electron with: npm start",
    "react-dev": "react-scripts start",
    "build": "react-scripts build",
    "electron-pack": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chart.js": "^4.5.1",
    "date-fns": "^2.30.0",
    "form-data": "^4.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-datepicker": "^4.21.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "wait-on": "^7.2.0"
  },
  "homepage": "./",
  "author": {
    "name": "Face Recognition Team",
    "email": "support@example.com"
  },
  "build": {
    "extends": null,
    "appId": "com.facerecognition.app",
    "productName": "Face Recognition System",
    "win": {
      "target": "nsis"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
